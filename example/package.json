{
	"name": "rpc-example",
	"displayName": "rpc-example",
	"description": "",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.38.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:extension.openwebview",
		"onCommand:extension.sendMessage"
	],
	"main": "./out/extension",
	"contributes": {
		"commands": [
			{
				"command": "extension.openwebview",
				"title": "Webview RPC: Open Webview"
			},
			{
				"command": "extension.sendMessage",
				"title": "Webview RPC: Send Message to Webview"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/node": "^18.11.1",
		"@types/vscode": "^1.83.3",
		"glob": "^7.1.6",
		"mocha": "^10.4.0",
		"rimraf": "^5.0.5",
		"typescript": "^5.4.5",
		"vscode-test": "^1.6.1"
	},
	"dependencies": {
		"@sap-devx/webview-rpc": "^1.0.0"
	}
}
